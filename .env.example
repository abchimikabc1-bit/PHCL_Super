# ...existing code...
ADMIN_SESSION_MAX_AGE_SECONDS=28800
ADMIN_SESSION_IDLE_TIMEOUT_SECONDS=1800
# ...existing code...
# PHCL Super Environment Variables
# Copy this file to .env.local and fill in the actual values

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://phclsuper.com
NEXT_PUBLIC_API_URL=https://api.phclsuper.com
NEXT_PUBLIC_APP_NAME=PHCL Super

# Analytics
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_SEGMENT_ID=

# API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Crypto APIs
NEXT_PUBLIC_COINGECKO_API_KEY=
NEXT_PUBLIC_BLOCKCHAIN_API_KEY=

# Email Service
NEXT_PUBLIC_SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=support@phclsuper.com

# Database (if using)
DATABASE_URL=

# Auth (if using NextAuth)
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://phclsuper.com

# Pi Network SDK
NEXT_PUBLIC_PI_SDK_ENABLED=true

# Feature Flags
NEXT_PUBLIC_ENABLE_CRYPTO_PAYMENTS=true
NEXT_PUBLIC_ENABLE_FIAT_PAYMENTS=true
NEXT_PUBLIC_ENABLE_MULTI_LANGUAGE=true
NEXT_PUBLIC_ENABLE_DARK_MODE=true

# Performance
NEXT_PUBLIC_CACHE_STRATEGY=swr
NEXT_PUBLIC_REVALIDATE_TIME=3600

# Security
NEXT_PUBLIC_ENABLE_CSP=true
NEXT_PUBLIC_ENABLE_HSTS=true
ADMIN_EMAIL=admin@phclsuper.com
ADMIN_PASSWORD=change-this-password
ADMIN_SESSION_SECRET=change-this-long-random-secret
ADMIN_AUTH_AUDIT_LOG_PATH=generated/security/admin-auth-audit.log
ADMIN_AUTH_RATE_LIMIT_PATH=generated/security/admin-auth-rate-limit.json
cd "c:\Users\USER\Desktop\PHCL Super"
Copy-Item ".env.example" ".env.local" -Force
